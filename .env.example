# Required — must be set before running qa_agent.py
TENANT_URL=https://example.com/login
TENANT_USERNAME=demo@example.com
TENANT_PASSWORD=yourpassword
TENANT_NAME=Docupilot

# Optional — Google Drive/Sheets integration
DRIVE_FOLDER_ID=
EXCEL_FILE_ID=

# Optional — runtime tuning
QA_MAX_BFS_STATES=60
QA_MAX_NAV_ITEMS=16
QA_MAX_BTN_PER_PAGE=15
QA_LOG_LEVEL=INFO
