# Required — must be set before running qa_agent.py directly
# (run.sh sets TENANT_URL/TENANT_USERNAME automatically based on test1..test6)
TENANT_URL=https://example.com/login
TENANT_USERNAME=demo@example.com
TENANT_PASSWORD=yourpassword
TENANT_NAME=Docupilot

# Google integration (optional)
EXCEL_FILE_ID=<google-sheets-file-id>

# Per-tenant credentials loaded by run.sh (override the defaults in the script)
DOCUPILOT_USERNAME=demo1@example.com
DOCUPILOT_DRIVE_FOLDER_ID=<folder-id>
CFO_USERNAME=demo2@example.com
CFO_DRIVE_FOLDER_ID=<folder-id>
MAIHUB_USERNAME=demo3@example.com
MAIHUB_DRIVE_FOLDER_ID=<folder-id>
ROOMS_USERNAME=demo4@example.com
ROOMS_DRIVE_FOLDER_ID=<folder-id>
A33_USERNAME=demo5@example.com
A33_DRIVE_FOLDER_ID=<folder-id>
CORE_USERNAME=demo6@example.com
CORE_DRIVE_FOLDER_ID=<folder-id>

# Optional — runtime tuning
QA_MAX_BFS_STATES=60
QA_MAX_NAV_ITEMS=16
QA_MAX_BTN_PER_PAGE=15
QA_LOG_LEVEL=INFO
